  function loadStr(key, def) {
    try { return typeof GM_getValue === 'function' ? GM_getValue(key, def) : def; } catch (e) { return def; }
  }
  function saveStr(key, val) {
    try { if (typeof GM_setValue === 'function') GM_setValue(key, val); } catch (e) {}
  }

  function todayIso() {
    const d = new Date();
    const pad = n => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
  }

  // Format attendu par <input type="datetime-local"> : "YYYY-MM-DDTHH:mm" (heure locale du navigateur).
  function toDatetimeLocalValue(d) {
    const pad = n => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  function defaultStartDateTime() {
    const d = new Date();
    d.setHours(0, 0, 0, 0);
    return toDatetimeLocalValue(d);
  }

  function defaultEndDateTime() {
    const d = new Date();
    d.setHours(23, 59, 0, 0);
    return toDatetimeLocalValue(d);
  }

  // datetime-local ("YYYY-MM-DDTHH:mm") est parsé nativement comme heure locale par `new Date()`,
  // ce qui reste cohérent avec parseFcrDate() (qui traite aussi les dates FCR comme heure locale du navigateur).
  function parseDatetimeLocal(str) {
    if (!str) return null;
    const d = new Date(str);
    return isNaN(d.getTime()) ? null : d;
  }

  function dateOnlyIso(d) {
    if (!d) return null;
    const pad = n => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
  }

  // Construit l'objet range { startDate, endDate, startDateISO, endDateISO } à partir des
  // valeurs brutes des deux champs datetime-local. Retourne null si invalide/incohérent.
  function buildDateTimeRange(startRaw, endRaw) {
    const startDate = parseDatetimeLocal(startRaw);
    const endDate = parseDatetimeLocal(endRaw);
    if (!startDate || !endDate) return null;
    if (startDate.getTime() > endDate.getTime()) return null;
    return {
      startDate, endDate,
      startDateISO: dateOnlyIso(startDate),
      endDateISO: dateOnlyIso(endDate),
    };
  }

  function formatDatetimeLabel(d) {
    if (!d) return '';
    const pad = n => String(n).padStart(2, '0');
    return `${pad(d.getDate())}/${pad(d.getMonth() + 1)}/${d.getFullYear()} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  // Parse une ligne de la textarea "login" ou "login:heures" (override du nb
  // d'heures travaillées pour ce sweeper précis, sinon on retombe sur la valeur
  // globale du champ "Heures travaillées (défaut)").
  function parseLoginLines(raw, defaultShiftHours) {
    return raw
      .split(/[\n,;]+/)
      .map(s => s.trim())
      .filter(Boolean)
      .map(line => {
        const m = line.match(/^([^\s:]+)\s*[:=]?\s*([\d.,]+)?$/);
        if (!m) return { login: line, shiftHours: defaultShiftHours };
        const shiftHours = m[2] ? parseFloat(m[2].replace(',', '.')) : defaultShiftHours;
        return { login: m[1], shiftHours: Number.isFinite(shiftHours) && shiftHours > 0 ? shiftHours : defaultShiftHours };
      });
  }

  function fmtNum(v, digits = 1) {
    if (v == null || !Number.isFinite(v)) return '—';
    return v.toFixed(digits);
  }

  // Rend une valeur numérique avec un badge ▲/▼ indiquant sa position par rapport à
  // la médiane d'équipe. `higherIsBetter` inverse la couleur (ex: plus d'arrêts =
  // moins bon, alors que plus d'actions/h = meilleur).
  function deltaBadge(value, teamMedian, higherIsBetter) {
    if (value == null || teamMedian == null || !Number.isFinite(value) || !Number.isFinite(teamMedian) || teamMedian === 0) return '';
    const pct = ((value - teamMedian) / teamMedian) * 100;
    if (Math.abs(pct) < 1) return '';
    const isUp = pct > 0;
    const good = higherIsBetter ? isUp : !isUp;
    const cls = good ? 'up' : 'down';
    const arrow = isUp ? '▲' : '▼';
    return ` <span class="fcr-cmp-delta ${cls}">${arrow}${Math.abs(pct).toFixed(0)}%</span>`;
  }

