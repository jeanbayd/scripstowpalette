    });

    goBtn.addEventListener('click', async () => {
      const rawLogins = loginsEl.value.trim();
      if (!rawLogins) { log('⚠️ Renseigne au moins un login AA.'); return; }
      const startRaw = startEl.value;
      const endRaw = endEl.value;
      if (!startRaw || !endRaw) { log('⚠️ Renseigne une date/heure de début et de fin.'); return; }
      const range = buildDateTimeRange(startRaw, endRaw);
      if (!range) { log('⚠️ Période invalide : la fin doit être après le début.'); return; }
      const shiftHoursDefault = parseFloat(shiftEl.value) || SHIFT_HOURS_DEFAULT;
      const thresholdMin = parseInt(thresholdEl.value, 10) || GAP_MIN_DEFAULT;
      const resolveStations = stationsEl.checked;

      saveStr(GM_KEYS.logins, rawLogins);
      saveStr(GM_KEYS.startDateTime, startRaw);
      saveStr(GM_KEYS.endDateTime, endRaw);
      saveStr(GM_KEYS.shiftHours, shiftHoursDefault);
      saveStr(GM_KEYS.thresholdMin, thresholdMin);
      saveStr(GM_KEYS.resolveStations, resolveStations);

      const entries = parseLoginLines(rawLogins, shiftHoursDefault);
      if (!entries.length) { log('⚠️ Aucun login valide détecté.'); return; }

      currentController = new AbortController();
      const signal = currentController.signal;
      setBusy(true);
      exportBtn.style.display = 'none';
      resultsEl.innerHTML = '';
      const perLoginStatus = {};
      entries.forEach(e => { perLoginStatus[e.login] = 'en attente…'; });
      const renderStatus = () => {
        statusEl.textContent = entries.map(e => `${e.login}: ${perLoginStatus[e.login]}`).join('\n');
      };
      renderStatus();

      const results = new Array(entries.length);
      try {
        await mapWithConcurrency(entries, SWEEPER_CONCURRENCY, async (entry, idx) => {
          try {
            const res = await analyzeSweeper(
              entry.login, range, thresholdMin, entry.shiftHours, resolveStations,
              (login, msg) => { perLoginStatus[login] = msg; renderStatus(); },
              signal
            );
            perLoginStatus[entry.login] = `✅ ${res.totalActions} action(s)`;
            results[idx] = res;
          } catch (e) {
            if (e && e.name === 'AbortError') throw e;
            perLoginStatus[entry.login] = `❌ ${e.message}`;
            results[idx] = { login: entry.login, error: e.message };
          }
          renderStatus();
        }, signal);

        lastRun = { entries, results, range, thresholdMin, resolveStations };
        renderResults(resultsEl, results, thresholdMin, resolveStations, range);
        exportBtn.style.display = results.some(r => !r.error) ? 'inline-block' : 'none';
        statusEl.textContent = `Terminé — ${results.filter(r => !r.error).length}/${results.length} sweeper(s) analysé(s) avec succès (période : ${formatDatetimeLabel(range.startDate)} → ${formatDatetimeLabel(range.endDate)}).`;
      } catch (e) {
        if (e && e.name === 'AbortError') {
          statusEl.textContent = '⏹ Analyse annulée.';
        } else {
          statusEl.textContent = `❌ Erreur inattendue : ${e.message}`;
          console.error('FCR Cmp:', e);
        }
      } finally {
        setBusy(false);
        currentController = null;
      }
    });

    exportBtn.addEventListener('click', () => {
      if (lastRun) exportCsv(lastRun.results, lastRun.range);
    });
  }

  function renderResults(container, results, thresholdMin, resolveStations, range) {
    const ok = results.filter(r => !r.error);
    if (!ok.length) {
      container.innerHTML = '<span class="fcr-cmp-error">Aucun résultat exploitable.</span>';
      return;
    }

    const teamMedianActions = median(ok.map(r => r.totalActions));
    const teamMedianRate = median(ok.map(r => r.actionsPerHour).filter(v => v != null));
    const teamMedianGapsTotal = median(ok.map(r => r.gapsTotalMin));
    const teamMedianGapsCount = median(ok.map(r => r.gaps.length));
    const teamMedianInterval = median(ok.map(r => r.medianIntervalMin).filter(v => v != null));
    const teamMedianStations = resolveStations ? median(ok.map(r => r.distinctStations).filter(v => v != null)) : null;

    const teamMeanActions = mean(ok.map(r => r.totalActions));
    const teamMeanRate = mean(ok.map(r => r.actionsPerHour).filter(v => v != null));
    const teamMeanGapsTotal = mean(ok.map(r => r.gapsTotalMin));
    const teamMeanInterval = mean(ok.map(r => r.medianIntervalMin).filter(v => v != null));
    const teamMeanStations = resolveStations ? mean(ok.map(r => r.distinctStations).filter(v => v != null)) : null;

    const stationsHeader = resolveStations ? '<th>Stations distinctes</th>' : '';

    const rowsHtml = results.map((r, i) => {
      if (r.error) {
        return `<tr><td class="fcr-cmp-login">${escapeHtml(r.login)}</td><td colspan="6" class="fcr-cmp-error">${escapeHtml(r.error)}</td></tr>`;
      }
      const gapsToggle = r.gaps.length
        ? `<div class="fcr-cmp-gaps-toggle" data-toggle-gaps="${i}">${r.gaps.length} arrêt(s) ▾</div>`
        : '<span style="color:var(--c-muted)">aucun</span>';
      const gapsDetail = r.gaps.length
        ? `<tr class="fcr-cmp-gaps-detail" id="fcr-cmp-gaps-${i}" style="display:none;"><td colspan="${resolveStations ? 7 : 6}">
             <table><tbody>
               ${r.gaps.map(g => `<tr><td class="inner">${g.from.slice(11)} → ${g.to.slice(11)}</td><td class="inner fcr-cmp-num">${g.durationMin} min${g.excludedMin ? ` (−${g.excludedMin} min pause)` : ''}</td></tr>`).join('')}
             </tbody></table>
           </td></tr>`
        : '';
      const stationsCell = resolveStations
        ? `<td class="fcr-cmp-num">${r.distinctStations != null ? r.distinctStations : '—'}${deltaBadge(r.distinctStations, teamMedianStations, true)}</td>`
        : '';
      return `
        <tr>
          <td class="fcr-cmp-login">${escapeHtml(r.login)}</td>
          <td class="fcr-cmp-num">${r.totalActions}${deltaBadge(r.totalActions, teamMedianActions, true)}</td>
          <td class="fcr-cmp-num">${fmtNum(r.actionsPerHour, 2)}${deltaBadge(r.actionsPerHour, teamMedianRate, true)}</td>
          <td class="fcr-cmp-num">${fmtNum(r.medianIntervalMin, 1)} min${deltaBadge(r.medianIntervalMin, teamMedianInterval, false)}</td>
          <td>${gapsToggle}</td>
          <td class="fcr-cmp-num">${formatDurationMin(r.gapsTotalMin)}${deltaBadge(r.gapsTotalMin, teamMedianGapsTotal, false)}</td>
          ${stationsCell}
        </tr>${gapsDetail}`;
    }).join('');

    const benchmarkRow = `
      <tr class="fcr-cmp-benchmark">
        <td>Médiane équipe</td>
        <td class="fcr-cmp-num">${fmtNum(teamMedianActions, 1)}</td>
        <td class="fcr-cmp-num">${fmtNum(teamMedianRate, 2)}</td>
        <td class="fcr-cmp-num">${fmtNum(teamMedianInterval, 1)} min</td>
        <td class="fcr-cmp-num">${fmtNum(teamMedianGapsCount, 1)}</td>
        <td class="fcr-cmp-num">${formatDurationMin(Math.round(teamMedianGapsTotal || 0))}</td>
        ${resolveStations ? `<td class="fcr-cmp-num">${fmtNum(teamMedianStations, 1)}</td>` : ''}
      </tr>
      <tr class="fcr-cmp-benchmark">
        <td>Moyenne équipe</td>
        <td class="fcr-cmp-num">${fmtNum(teamMeanActions, 1)}</td>
        <td class="fcr-cmp-num">${fmtNum(teamMeanRate, 2)}</td>
        <td class="fcr-cmp-num">${fmtNum(teamMeanInterval, 1)} min</td>
        <td class="fcr-cmp-num">—</td>
        <td class="fcr-cmp-num">${formatDurationMin(Math.round(teamMeanGapsTotal || 0))}</td>
        ${resolveStations ? `<td class="fcr-cmp-num">${fmtNum(teamMeanStations, 1)}</td>` : ''}
      </tr>`;

    container.innerHTML = `
      <div class="fcr-cmp-note">Période analysée : ${range ? `${formatDatetimeLabel(range.startDate)} → ${formatDatetimeLabel(range.endDate)}` : '—'}. Les badges ▲/▼ situent chaque AA par rapport à la médiane de l'équipe (vert = plus favorable, rouge = moins favorable). Seuil d'arrêt : ${thresholdMin} min.</div>
      <table class="fcr-cmp-table">
        <thead>
          <tr>
            <th>AA</th>
            <th>Actions (total)</th>
            <th>Actions / h</th>
            <th>Temps médian entre actions</th>
            <th>Arrêts (≥ ${thresholdMin} min)</th>
            <th>Total arrêts</th>
            ${stationsHeader}
          </tr>
        </thead>
        <tbody>${rowsHtml}${benchmarkRow}</tbody>
      </table>`;

    container.querySelectorAll('[data-toggle-gaps]').forEach(el => {
      el.addEventListener('click', () => {
        const idx = el.getAttribute('data-toggle-gaps');
        const row = container.querySelector(`#fcr-cmp-gaps-${idx}`);
        if (!row) return;
        const willOpen = row.style.display === 'none';
        row.style.display = willOpen ? 'table-row' : 'none';
        el.textContent = el.textContent.replace(willOpen ? '▾' : '▴', willOpen ? '▴' : '▾');
      });
    });
  }

  function exportCsv(results, range) {
    const lines = [];
    if (range) {
      lines.push(`"Période analysée : ${formatDatetimeLabel(range.startDate)} → ${formatDatetimeLabel(range.endDate)}"`);
      lines.push('');
    }
    const header = ['Login', 'ActionsTotal', 'ActionsParHeure', 'TempsMoyenEntreActionsMin', 'TempsMedianEntreActionsMin', 'NbArrets', 'TotalArretsMin', 'StationsDistinctes', 'PremiereAction', 'DerniereAction', 'Erreur'];
    lines.push(header.join(';'));
    for (const r of results) {
      lines.push([
        r.login, r.totalActions ?? '', r.actionsPerHour != null ? r.actionsPerHour.toFixed(2) : '',
        r.avgIntervalMin != null ? r.avgIntervalMin.toFixed(1) : '', r.medianIntervalMin != null ? r.medianIntervalMin.toFixed(1) : '',
        r.gaps ? r.gaps.length : '', r.gapsTotalMin ?? '', r.distinctStations != null ? r.distinctStations : '',
        r.firstAction || '', r.lastAction || '', r.error || '',
      ].map(v => `"${String(v).replace(/"/g, '""')}"`).join(';'));
    }
    // Détail des arrêts par sweeper, en dessous, pour audit
    lines.push('');
    lines.push('"--- Détail des arrêts par AA ---"');
    lines.push(['Login', 'De', 'A', 'DureeMin'].join(';'));
    for (const r of results) {
      if (!r.gaps) continue;
      for (const g of r.gaps) {
        lines.push([r.login, g.from, g.to, g.durationMin].map(v => `"${String(v).replace(/"/g, '""')}"`).join(';'));
      }
    }
    const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `fcr-sweeper-comparator-${Date.now()}.csv`;
    a.click();
  }

  function makeDraggable(panel, handle) {
    let ox, oy, dragging = false;
    handle.addEventListener('mousedown', e => {
      dragging = true;
      const rect = panel.getBoundingClientRect();
      ox = e.clientX - rect.left;
      oy = e.clientY - rect.top;
      panel.style.right = 'auto';
      panel.style.bottom = 'auto';
    });
    document.addEventListener('mousemove', e => {
      if (!dragging) return;
      panel.style.left = e.clientX - ox + 'px';
      panel.style.top = e.clientY - oy + 'px';
    });
    document.addEventListener('mouseup', () => (dragging = false));
  }

  /* =========================================================
   *  INIT
   * ========================================================= */
  if (!document.getElementById('fcr-cmp-panel')) buildPanel();
})();
