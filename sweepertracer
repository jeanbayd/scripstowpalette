  function injectPanelCss() {
    if (document.getElementById('fcr-trace-css')) return;
    const style = document.createElement('style');
    style.id = 'fcr-trace-css';
    style.textContent = PANEL_CSS;
    document.head.appendChild(style);
  }

  function buildPanel() {
    injectPanelCss();
    const panel = document.createElement('div');
    panel.id = 'fcr-trace-panel';
    panel.innerHTML = `
      <div id="fcr-trace-header">
        <strong>🕵️ FCR Trace Sweeper</strong>
        <button id="fcr-trace-collapse" title="Réduire / agrandir">—</button>
      </div>
      <div id="fcr-trace-body">
        <div class="fcr-controls">
          <input type="date" id="fcr-trace-date">
          <button id="fcr-trace-go">Tracer</button>
        </div>
        <div class="fcr-threshold-row">
          <span>⏸ Seuil "temps sans action" :</span>
          <input type="number" id="fcr-trace-threshold" min="1" step="1">
          <span>min</span>
        </div>
        <div id="fcr-trace-status"></div>
        <div id="fcr-trace-results"></div>
        <button id="fcr-trace-export">⬇ Exporter CSV</button>

        <div class="fcr-section-divider">🔎 Analyser un AA directement (login + date, sans naviguer sur sa page)</div>
        <div class="fcr-direct-controls">
          <input type="text" id="fcr-direct-login" placeholder="login AA (ex: jeanbayd)">
          <input type="date" id="fcr-direct-date">
          <button id="fcr-direct-go">Analyser</button>
        </div>
        <div id="fcr-direct-status"></div>
        <div id="fcr-direct-results"></div>
        <button id="fcr-direct-export">⬇ Exporter CSV</button>
      </div>
    `;
    document.body.appendChild(panel);

    // date par défaut = aujourd'hui (pour le traçage ET la recherche directe)
    const today = new Date().toISOString().slice(0, 10);
    panel.querySelector('#fcr-trace-date').value = today;
    panel.querySelector('#fcr-direct-date').value = today;

    // seuil d'inactivité : chargé depuis GM_getValue (ou défaut 15 min), et sauvegardé
    // via GM_setValue à chaque modification pour être réutilisé aux prochaines analyses.
    const thresholdInput = panel.querySelector('#fcr-trace-threshold');
    thresholdInput.value = loadInactivityThresholdMin();
    thresholdInput.addEventListener('change', () => {
      const n = Number(thresholdInput.value);
      if (Number.isFinite(n) && n > 0) {
        saveInactivityThresholdMin(n);
      } else {
        thresholdInput.value = inactivityThresholdMin; // valeur invalide -> on revient à la dernière valeur valide
      }
    });

    // collapse/expand
    const body = panel.querySelector('#fcr-trace-body');
    panel.querySelector('#fcr-trace-collapse').addEventListener('click', () => {
      body.style.display = body.style.display === 'none' ? 'block' : 'none';
    });

    // drag basique
    makeDraggable(panel, panel.querySelector('#fcr-trace-header'));

    let lastResults = [];
    let lastGaps = [];
    let lastThresholdMin = inactivityThresholdMin;

    let lastDirectResults = [];
    let lastDirectGaps = [];
    let lastDirectThresholdMin = inactivityThresholdMin;

    // Lance le pipeline complet (inventaire -> totes -> container history -> station,
    // avec résolution RoboScout priorisée) soit sur la page AA courante (sourceLogin
    // null), soit sur celle d'un AUTRE AA chargée en arrière-plan via son login.
    async function runAnalysis({ dateVal, sourceLogin, statusEl, resultsEl, exportBtn, onDone }) {
      resultsEl.innerHTML = '';
      exportBtn.style.display = 'none';
      statusEl.textContent = sourceLogin
        ? `⏳ Chargement de la page de "${sourceLogin}" en arrière-plan...`
        : '⏳ Lecture de l\'historique inventaire...';

      const thresholdMin = inactivityThresholdMin;
      try {
        const { results, gaps } = await traceSweeper(
          dateVal,
          (done, total, tote) => {
            statusEl.textContent = `⏳ Analyse tote ${done}/${total} (${tote})...`;
          },
          msg => {
            statusEl.textContent = msg;
          },
          thresholdMin,
          sourceLogin
        );
        statusEl.textContent = '⏳ Résolution des stations (RoboScout)...';
        await enrichStationsViaRoboScout(results, (done, total, login) => {
          statusEl.textContent = `⏳ Résolution station ${done}/${total} (${login})...`;
        });

        // On retire les lignes dont la localisation finale est restée un code
        // "pc99xxxxx" brut (résolution RoboScout échouée ou impossible) : ce n'est
        // pas une station physique exploitable.
        const filtered = results.filter(r => !(r.station && /^pc99/i.test(r.station)));

        const groups = buildGroups(filtered);
        const removedCount = results.length - filtered.length;
        statusEl.textContent = `✅ ${filtered.length} mouvement(s) tracé(s) (${groups.length} localisation(s) distincte(s))` +
          (removedCount ? `, ${removedCount} ligne(s) non localisée(s) retirée(s).` : '.');
        renderResults(resultsEl, groups, gaps, thresholdMin);
        exportBtn.style.display = filtered.length ? 'inline-block' : 'none';
        onDone && onDone(filtered, gaps, thresholdMin);
      } catch (e) {
        console.error('FCR Trace Sweeper:', e);
        statusEl.textContent = '❌ Erreur: ' + e.message + ' (voir console)';
      }
    }

    panel.querySelector('#fcr-trace-go').addEventListener('click', () => {
      runAnalysis({
        dateVal: panel.querySelector('#fcr-trace-date').value,
        sourceLogin: null,
        statusEl: panel.querySelector('#fcr-trace-status'),
        resultsEl: panel.querySelector('#fcr-trace-results'),
        exportBtn: panel.querySelector('#fcr-trace-export'),
        onDone: (filtered, gaps, thresholdMin) => {
          lastResults = filtered;
          lastGaps = gaps;
          lastThresholdMin = thresholdMin;
        },
      });
    });

    panel.querySelector('#fcr-trace-export').addEventListener('click', () => {
      exportCsv(lastResults, lastGaps, lastThresholdMin);
    });

    // --- Analyse directe d'un AA distant (login + date), sans naviguer sur sa page :
    // même pipeline complet que le bouton "Tracer" ci-dessus, mais l'historique
    // inventaire est chargé pour le login indiqué via un iframe caché.
    panel.querySelector('#fcr-direct-go').addEventListener('click', () => {
      const login = panel.querySelector('#fcr-direct-login').value.trim();
      const dateVal = panel.querySelector('#fcr-direct-date').value;
      const statusEl = panel.querySelector('#fcr-direct-status');

      if (!login) {
        statusEl.textContent = '⚠️ Renseigner un login AA.';
        return;
      }
      if (!dateVal) {
        statusEl.textContent = '⚠️ Renseigner une date.';
        return;
      }

      runAnalysis({
        dateVal,
        sourceLogin: login,
        statusEl,
        resultsEl: panel.querySelector('#fcr-direct-results'),
        exportBtn: panel.querySelector('#fcr-direct-export'),
        onDone: (filtered, gaps, thresholdMin) => {
          lastDirectResults = filtered;
          lastDirectGaps = gaps;
          lastDirectThresholdMin = thresholdMin;
        },
      });
    });

    panel.querySelector('#fcr-direct-export').addEventListener('click', () => {
      exportCsv(lastDirectResults, lastDirectGaps, lastDirectThresholdMin);
    });
  }

  // Regroupe les lignes successives (déjà triées chronologiquement) partageant la
  // même tote en un seul "groupe" affichable, avec un compteur d'occurrences et le
  // détail dépliable des lignes individuelles.
  function buildGroups(results) {
    const groups = [];
    for (const r of results) {
      const last = groups[groups.length - 1];
      if (last && last.tote === r.tote) {
        last.rows.push(r);
        last.lastDate = r.date;
      } else {
        groups.push({ tote: r.tote, station: r.station, firstDate: r.date, lastDate: r.date, rows: [r] });
      }
    }
    return groups;
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  }

  // Raccourcit un code station en ne gardant que sa partie numérique finale.
  // Ex: "dz-P-A2148" -> "2148", "A2133" -> "2133". Si aucun nombre n'est trouvé,
  // renvoie le code tel quel (fallback pour un format inattendu).
  function formatStationLabel(station) {
    if (!station) return station;
    const m = String(station).match(/(\d+)\D*$/);
    return m ? m[1] : station;
  }

  // Formate un nombre de minutes en "1h23min" (ou "45min" si < 1h).
  function formatDurationMin(totalMin) {
    const h = Math.floor(totalMin / 60);
    const m = totalMin % 60;
    return h > 0 ? `${h}h${String(m).padStart(2, '0')}min` : `${m}min`;
  }

  function renderResults(container, groups, gaps, thresholdMin = inactivityThresholdMin) {
    if (!groups.length) {
      container.innerHTML = '<span class="fcr-empty">Aucun mouvement de tote trouvé pour cette date.</span>';
      return;
    }

    const bodyRows = groups
      .map((g, gi) => {
        const first = g.rows[0];
        const stationRaw = g.station || first.containerCode || '?';
        const stationLabel = formatStationLabel(stationRaw);
        const unreliableTitle = first.matchUnreliable
          ? ' title="Match peu fiable (écart temporel important ou pas de code trouvé)"'
          : '';
        const count = g.rows.length;
        const badge = count > 1
          ? `<span class="fcr-count-badge" data-toggle="${gi}" title="Cliquer pour voir le détail">${count}× ▾</span>`
          : '';
        const detailRows = g.rows
          .map(
            r => `
              <tr>
                <td class="fcr-time">${r.date.slice(11)}</td>
                <td>${escapeHtml(r.asin || '')}</td>
              </tr>`
          )
          .join('');
        const detailBlock = count > 1
          ? `<tr class="fcr-detail-row" id="fcr-trace-detail-${gi}" style="display:none;"><td colspan="4">
               <table class="fcr-detail-table"><tbody>${detailRows}</tbody></table>
             </td></tr>`
          : '';
        return `
          <tr class="fcr-row"${unreliableTitle}>
            <td class="fcr-time">${g.firstDate.slice(11)}${count > 1 ? ' → ' + g.lastDate.slice(11) : ''}</td>
            <td>${escapeHtml(first.asin || '')}</td>
            <td class="fcr-tote">${escapeHtml(g.tote)}${badge}</td>
            <td><span class="fcr-station-pill" title="${escapeHtml(stationRaw)}">${escapeHtml(stationLabel)}</span></td>
          </tr>${detailBlock}`;
      })
      .join('');

    const gapsTotalMin = gaps ? gaps.reduce((sum, g) => sum + g.durationMin, 0) : 0;
    const gapsBlock = gaps && gaps.length
      ? `
        <div class="fcr-gaps-card">
          <div class="fcr-gaps-title">⏸ Temps sans action (≥ ${thresholdMin} min)</div>
          <div class="fcr-gaps-note">Les pauses planifiées (ex: 10h00–10h30) sont déduites et ne comptent pas comme arrêt.</div>
          <table class="fcr-table">
            <thead>
              <tr><th>De</th><th>À</th><th>Durée</th></tr>
            </thead>
            <tbody>
              ${gaps
                .map(
                  g => `
                <tr class="fcr-row">
                  <td class="fcr-time">${g.from.slice(11)}</td>
                  <td class="fcr-time">${g.to.slice(11)}</td>
                  <td class="fcr-gap-duration">${g.durationMin} min${g.excludedMin ? ` <span class="fcr-gaps-note" style="display:inline">(−${g.excludedMin} min pause)</span>` : ''}</td>
                </tr>`
                )
                .join('')}
            </tbody>
            <tfoot>
              <tr class="fcr-row" style="border-top:1px solid var(--fcr-border);">
                <td colspan="2" style="font-weight:700;">Total (pause déduite)</td>
                <td class="fcr-gap-duration">${formatDurationMin(gapsTotalMin)}</td>
              </tr>
            </tfoot>
          </table>
        </div>`
      : '';

    container.innerHTML = `
      <table class="fcr-table">
        <thead>
          <tr><th>Heure</th><th>ASIN</th><th>Tote</th><th>Station</th></tr>
        </thead>
        <tbody>${bodyRows}</tbody>
      </table>
      ${gapsBlock}`;

    // Toggle du détail dépliable pour les groupes avec plusieurs occurrences.
    container.querySelectorAll('[data-toggle]').forEach(badgeEl => {
      badgeEl.addEventListener('click', () => {
        const idx = badgeEl.getAttribute('data-toggle');
        const row = container.querySelector(`#fcr-trace-detail-${idx}`);
        if (!row) return;
        const willOpen = row.style.display === 'none';
        row.style.display = willOpen ? 'table-row' : 'none';
        badgeEl.textContent = badgeEl.textContent.replace(willOpen ? '▾' : '▴', willOpen ? '▴' : '▾');
      });
    });
  }

  function exportCsv(results, gaps, thresholdMin = inactivityThresholdMin) {
    const header = ['Date', 'ASIN', 'OldBin', 'NewBin', 'Tote', 'DateMatchContainer', 'EcartSec', 'MatchFiable', 'ContainerCode', 'Station', 'LocalisationHeritee'];
    const lines = [header.join(';')];
    for (const r of results) {
      lines.push(
        [
          r.date, r.asin, r.oldBin, r.newBin, r.tote,
          r.matchDate || '', r.matchDiffSec ?? '', r.matchUnreliable ? 'non' : 'oui',
          r.containerCode || '', r.station || '', r.inheritedLocation ? 'oui' : 'non',
        ]
          .map(v => `"${String(v).replace(/"/g, '""')}"`)
          .join(';')
      );
    }

    if (gaps && gaps.length) {
      const totalMin = gaps.reduce((sum, g) => sum + g.durationMin, 0);
      lines.push('');
      lines.push(`"--- Temps sans action (>= ${thresholdMin} min, pause deduite) ---"`);
      lines.push(['De', 'A', 'DureeMin'].join(';'));
      for (const g of gaps) {
        lines.push([g.from, g.to, g.durationMin].map(v => `"${String(v).replace(/"/g, '""')}"`).join(';'));
      }
      lines.push(['TOTAL', '', totalMin].map(v => `"${String(v).replace(/"/g, '""')}"`).join(';'));
    }

    const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `fcr-trace-sweeper-${Date.now()}.csv`;
    a.click();
  }

  function makeDraggable(panel, handle) {
    let ox, oy, dragging = false;
    handle.addEventListener('mousedown', e => {
      dragging = true;
      const rect = panel.getBoundingClientRect();
      ox = e.clientX - rect.left;
      oy = e.clientY - rect.top;
      panel.style.right = 'auto';
      panel.style.bottom = 'auto';
    });
    document.addEventListener('mousemove', e => {
      if (!dragging) return;
      panel.style.left = e.clientX - ox + 'px';
      panel.style.top = e.clientY - oy + 'px';
    });
    document.addEventListener('mouseup', () => (dragging = false));
  }

  /* =========================================================
   *  INIT — seulement si on est sur une page "personne" (AA)
   *  et pas sur une page "tote" / "container".
   * ========================================================= */

  waitFor(() => findTableById(document, 'table-inventory-history', ['old bin', 'new bin']), { timeout: 8000 })
    .then(() => {
      if (!document.getElementById('fcr-trace-panel')) buildPanel();
    })
    .catch(() => {
      // Pas de tableau Inventory History détecté (probablement une page tote) -> on ne fait rien.
    });
})();
